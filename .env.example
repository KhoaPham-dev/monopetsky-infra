# Copy this to .env (dev), .env.staging, or .env.prod and fill in real values.
# Never commit real secrets.

# --- Postgres ---
POSTGRES_USER=monopetsky
POSTGRES_PASSWORD=change_me
POSTGRES_DB=monopetsky
# Host port for Postgres in dev (override if you already have a local Postgres on 5432).
POSTGRES_HOST_PORT=5432

# --- Backend ---
# DATABASE_URL is consumed inside the backend container; postgres host is the compose service name.
DATABASE_URL=postgresql://monopetsky:change_me@postgres:5432/monopetsky
JWT_SECRET=change_me_to_a_long_random_string
BACKEND_PORT=5050
RUN_MIGRATIONS_ON_BOOT=true

# --- Frontend (storefront) ---
FRONTEND_PORT=5002
# Public URL the storefront bakes in at build time — must point at the public backend host.
NEXT_PUBLIC_API_URL=http://localhost:5050

# --- CMS (admin panel) ---
CMS_PORT=5001

# --- Public hosts (used by nginx in staging/prod) ---
# Replace with your real hostnames before deploying.
PUBLIC_FRONTEND_HOST=localhost
PUBLIC_CMS_HOST=localhost
PUBLIC_BACKEND_HOST=localhost

# --- TLS (staging/prod only) ---
LETSENCRYPT_EMAIL=ops@example.com

# --- Backups ---
BACKUP_RETENTION_DAYS=14

# --- Web Push (VAPID) — backend signs admin notifications with these ---
# Generate a fresh pair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@example.com

# --- Cloudflare Tunnel (only needed when deploying with --tunnel flag) ---
CLOUDFLARE_TUNNEL_TOKEN=
