# Production environment — copy to .env.prod on the VPS and fill in real values.
# This file MUST be readable only by the deploy user (chmod 600).

POSTGRES_USER=monopetsky
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=monopetsky

DATABASE_URL=postgresql://monopetsky:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/monopetsky
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
BACKEND_PORT=5050
RUN_MIGRATIONS_ON_BOOT=true

FRONTEND_PORT=5002
CMS_PORT=5001
# Replace with your real backend host (e.g. https://api.monopetsky.com)
NEXT_PUBLIC_API_URL=https://api.example.com

# CORS — must match the public hostnames of storefront and CMS
CORS_ORIGIN_STOREFRONT=https://example.com
CORS_ORIGIN_CMS=https://cms.example.com

# Replace with your real public hosts before running configure-nginx.sh
PUBLIC_FRONTEND_HOST=example.com
PUBLIC_CMS_HOST=cms.example.com
PUBLIC_BACKEND_HOST=api.example.com

LETSENCRYPT_EMAIL=ops@example.com

BACKUP_RETENTION_DAYS=30

# Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:ops@example.com
