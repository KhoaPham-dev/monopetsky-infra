# Staging environment — copy to .env.staging on the VPS and fill in real values.

POSTGRES_USER=monopetsky
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=monopetsky_staging

DATABASE_URL=postgresql://monopetsky:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/monopetsky_staging
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
BACKEND_PORT=4001
RUN_MIGRATIONS_ON_BOOT=true

FRONTEND_PORT=3010
CMS_PORT=3011
NEXT_PUBLIC_API_URL=https://api.staging.example.com

PUBLIC_FRONTEND_HOST=staging.example.com
PUBLIC_CMS_HOST=cms.staging.example.com
PUBLIC_BACKEND_HOST=api.staging.example.com

LETSENCRYPT_EMAIL=ops@example.com

BACKUP_RETENTION_DAYS=7

VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:ops@example.com

# --- Cloudflare Tunnel (only needed when deploying with --tunnel flag) ---
CLOUDFLARE_TUNNEL_TOKEN=
